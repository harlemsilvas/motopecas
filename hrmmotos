# ============================================================
# BLOCO 3: HTTP -> HTTPS Redirect (Dominios)
# ============================================================
server {
    listen 80;
    listen [::]:80;
    server_name hrmmotos.com.br www.hrmmotos.com.br ml.hrmmotos.com.br srv1433055.hstgr.cloud;
    include snippets/acme-challenge.conf;

    # ===== Redirect raiz para Instagram =====
    location = / {
        return 302 https://www.instagram.com/hrmmotos;
    }

    # ===== Demais caminhos: redirect para HTTPS =====
    location / {
        return 301 https://$host$request_uri;
    }

    error_page 404 /404.html;
    location = /404.html {
        root /var/www/html;
        internal;
    }
}
